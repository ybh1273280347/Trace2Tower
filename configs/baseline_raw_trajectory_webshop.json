{
  "env": {
    "name": "webshop",
    "mode": "text",
    "num_products": 1000
  },
  "agent": {
    "name": "smoke_random",
    "seed": 7
  },
  "segmenter": {
    "name": "rule"
  },
  "miner": {
    "name": "raw_trajectory"
  },
  "retriever": {
    "name": "similarity",
    "top_k": 3
  },
  "evaluator": {
    "metrics": [
      "success_rate",
      "reward",
      "step_count",
      "shortcut_rate"
    ]
  },
  "runtime": {
    "episodes": 3,
    "max_steps": 30,
    "output_dir": "experiments/baseline_raw_trajectory_webshop"
  }
}
