{
  "env": {
    "name": "alfworld",
    "mode": "text",
    "alfworld_config_path": "configs/alfworld/base_config.yaml",
    "alfworld_data_dir": ".external/alfworld"
  },
  "agent": {
    "name": "llm_action",
    "temperature": 0.0,
    "max_tokens": 128,
    "max_skill_chars": 0,
    "max_retries": 6,
    "retry_delay": 2.0
  },
  "segmenter": {
    "name": "rule"
  },
  "miner": {
    "name": "no_skill"
  },
  "retriever": {
    "name": "none",
    "top_k": 0
  },
  "evaluator": {
    "metrics": [
      "success_rate",
      "reward",
      "step_count",
      "token_cost"
    ]
  },
  "runtime": {
    "episodes": 3,
    "max_steps": 30,
    "output_dir": "experiments/baseline_no_skill_alfworld"
  }
}
