{
  "env": {
    "name": "webshop",
    "mode": "text",
    "num_products": 1000
  },
  "agent": {
    "name": "llm_action",
    "temperature": 0.0,
    "max_tokens": 128,
    "max_skill_chars": 2400,
    "max_retries": 6,
    "retry_delay": 2.0
  },
  "segmenter": {
    "name": "rule"
  },
  "miner": {
    "name": "no_skill"
  },
  "retriever": {
    "name": "embedding_pue_full",
    "top_k": 6,
    "level_top_k": {
      "high": 1,
      "mid": 2,
      "low": 3
    },
    "embedding_timeout": 120,
    "embedding_max_retries": 6,
    "embedding_retry_delay": 2.0,
    "embedding_batch_size": 8,
    "embedding_batch_delay": 0.5
  },
  "evaluator": {
    "metrics": [
      "success_rate",
      "reward",
      "step_count",
      "token_cost"
    ]
  },
  "runtime": {
    "episodes": 1,
    "max_steps": 10,
    "skill_model_path": "experiments/trace2tower_webshop/model.json",
    "output_dir": "experiments/llm_trace2tower_webshop"
  }
}
