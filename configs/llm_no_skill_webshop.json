{
  "env": {
    "name": "webshop",
    "mode": "text",
    "num_products": 1000
  },
  "agent": {
    "name": "llm_action",
    "temperature": 0.0,
    "max_tokens": 128,
    "max_skill_chars": 0
  },
  "segmenter": {
    "name": "rule"
  },
  "miner": {
    "name": "no_skill"
  },
  "retriever": {
    "name": "none",
    "top_k": 0
  },
  "evaluator": {
    "metrics": [
      "success_rate",
      "reward",
      "step_count",
      "token_cost"
    ]
  },
  "runtime": {
    "episodes": 1,
    "max_steps": 10,
    "output_dir": "experiments/llm_no_skill_webshop"
  }
}
