{
  "env": {
    "name": "alfworld",
    "mode": "text"
  },
  "agent": {
    "name": "llm_action",
    "temperature": 0.0,
    "max_tokens": 128,
    "max_skill_chars": 0,
    "max_retries": 6,
    "retry_delay": 2.0
  },
  "segmenter": {
    "name": "rule"
  },
  "miner": {
    "name": "no_skill"
  },
  "retriever": {
    "name": "none",
    "top_k": 0
  },
  "evaluator": {
    "metrics": [
      "success_rate",
      "step_count",
      "invalid_action_rate"
    ]
  },
  "runtime": {
    "episodes": 5,
    "max_steps": 50,
    "output_dir": "experiments/alfworld_text_only"
  }
}
